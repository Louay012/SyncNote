{
  "name": "syncnote-api",
  "version": "1.0.0",
  "description": "SyncNote collaborative document management API using GraphQL, PostgreSQL, and subscriptions",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "docs:generate": "magidoc generate --file ./magidoc.mjs --package-manager npm",
    "docs:preview": "magidoc preview --file ./magidoc.mjs --port 4100",
    "docs:dev": "magidoc dev --file ./magidoc.mjs --package-manager npm --port 4100",
    "db:setup": "node scripts/setup-postgres.js",
    "db:seed": "node scripts/seed-data.js",
    "lint": "echo \"No lint configured\""
  },
  "keywords": [
    "graphql",
    "apollo",
    "postgresql",
    "subscriptions",
    "collaboration"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@apollo/server": "^4.11.0",
    "@graphql-tools/schema": "^10.0.17",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dataloader": "^2.2.3",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "graphql": "^16.9.0",
    "graphql-subscriptions": "^2.0.0",
    "graphql-ws": "^5.16.2",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.5",
    "pg": "^8.13.1",
    "socket.io": "^4.8.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@magidoc/cli": "^6.3.0",
    "nodemon": "^3.1.4"
  }
}
