PORT=4000
POSTGRES_URI=postgres://postgres:postgres@127.0.0.1:5432/syncnote
# Optional: admin DB used only by npm run db:setup (defaults to same host/user with /postgres)
# POSTGRES_ADMIN_URI=postgres://postgres:postgres@127.0.0.1:5432/postgres
APP_URL=http://localhost:3000
JWT_SECRET=change_this_secret
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:3000

# SMTP settings (required for real verification and password reset emails)
# If left empty, SyncNote falls back to console logging for email payloads.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=SyncNote <no-reply@syncnote.local>

# Optional in production, defaults to false in production and true otherwise
# GRAPHQL_INTROSPECTION=false
